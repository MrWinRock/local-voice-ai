LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Language: "th" for Thai, "en" for English
LANGUAGE=th

# STT backend: "whisper" supports Thai; "nemotron" supports English only
# Use large-v3 for Thai — small/medium misidentify Thai speech as English
STT_PROVIDER=whisper
STT_BASE_URL=http://localhost:11437/v1
STT_MODEL=Systran/faster-whisper-large-v3
STT_API_KEY=no-key-needed

# TTS voice — edge-tts is used for Thai (Kokoro has no Thai support)
# Thai: th-TH-PremwadeeNeural (female), th-TH-NiwatNeural (male)
# English: af_nova (used with Kokoro)
TTS_VOICE=th-TH-PremwadeeNeural

# LLM backend
LLAMA_BASE_URL=http://localhost:11436/v1
LLAMA_MODEL=qwen3-4b
