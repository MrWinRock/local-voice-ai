LIVEKIT_URL=http://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
NEXT_PUBLIC_LIVEKIT_URL=http://localhost:7880

LLAMA_BASE_URL=http://llama_cpp:11434/v1
LLAMA_MODEL=qwen3-4b
LLAMA_MODEL_ALIAS=qwen3-4b
LLAMA_HF_REPO=unsloth/Qwen3-4B-Instruct-2507-GGUF
LLAMA_HOST_PORT=11436
LLAMA_CTX_SIZE=16384

# Language setting: "th" for Thai, "en" for English
LANGUAGE=th

# STT: Whisper is required for Thai (Nemotron supports English only)
# large-v3 is required for reliable Thai transcription; small/medium misidentify Thai as English
STT_PROVIDER=whisper
STT_BASE_URL=http://whisper:80/v1
STT_MODEL=Systran/faster-whisper-large-v3
STT_API_KEY=no-key-needed
VOXBOX_HF_REPO_ID=Systran/faster-whisper-large-v3
VOXBOX_DEVICE=cpu

# Nemotron (English-only STT, not used when LANGUAGE=th)
NEMOTRON_MODEL_NAME=nvidia/nemotron-speech-streaming-en-0.6b
NEMOTRON_MODEL_ID=nemotron-speech-streaming

# TTS voice (edge-tts used for Thai, kokoro for English)
# Thai options: th-TH-PremwadeeNeural (female), th-TH-NiwatNeural (male)
TTS_VOICE=th-TH-PremwadeeNeural

KOKORO_IMAGE=ghcr.io/remsky/kokoro-fastapi-cpu:latest
